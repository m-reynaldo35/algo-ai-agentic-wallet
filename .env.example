# ═══════════════════════════════════════════════════════════════════
# Algo AI Agentic Wallet — Environment Variable Matrix
#
# Local dev:  copy to .env
# Production: set in Railway Dashboard → Variables
#             (Railway injects PORT automatically — do not override)
#
# Developer portal stays on Vercel. Only this Express server moves
# to Railway. Update ai-agentic-wallet.com DNS to Railway's domain
# after first deploy: railway domain → set CNAME in your DNS panel.
# ═══════════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=4020

# ── Algorand Node (Nodely Free Tier) ─────────────────────────────
# No API key required. Cloudflare-balanced across 21+ global locations.
# Free tier adds 50ms artificial latency per request.
# Docs: https://nodely.io/docs/free/start/
#
# Mainnet Algod:   https://mainnet-api.4160.nodely.dev
# Mainnet Indexer: https://mainnet-idx.4160.nodely.dev
# Testnet Algod:   https://testnet-api.4160.nodely.dev
# Testnet Indexer: https://testnet-idx.4160.nodely.dev
ALGORAND_NODE_URL=https://mainnet-api.4160.nodely.dev
ALGORAND_INDEXER_URL=https://mainnet-idx.4160.nodely.dev
ALGORAND_NODE_TOKEN=
ALGORAND_NETWORK=mainnet

# ── x402 Protocol ───────────────────────────────────────────────
# Price in micro-USDC (6 decimals). 100000 = $0.10
X402_PRICE_MICROUSDC=100000
# ⚠️  REQUIRED: Paste your Algorand Mainnet treasury wallet address below.
#     This address receives ALL x402 toll payments.
X402_PAY_TO_ADDRESS=<YOUR_MAINNET_TREASURY_ADDRESS>
# USDC ASA ID — Mainnet: 31566704 (Circle USDC)
X402_USDC_ASSET_ID=31566704

# ── Liquid Auth (FIDO2 / Passkey) ────────────────────────────────
# ⚠️  PRODUCTION REQUIRED: assertProductionAuthReady() blocks boot if
#     NODE_ENV=production and LIQUID_AUTH_SERVER_URL is blank.
#     In development, a mock HMAC token path is used automatically.
# Relying Party ID — must match the domain serving the FIDO2 challenge
FIDO2_RP_ID=
# Relying Party Name — human-readable label shown in passkey prompts
FIDO2_RP_NAME=Algo AI Wallet
# Liquid Auth server URL for challenge/verify endpoints
LIQUID_AUTH_SERVER_URL=
# Expected origin for WebAuthn assertion validation
LIQUID_AUTH_EXPECTED_ORIGIN=

# ── Rocca Wallet (Seedless Signing) ─────────────────────────────
# Rocca API key for authenticated SDK calls
ROCCA_API_KEY=
# Rocca environment: "sandbox" | "production"
ROCCA_ENVIRONMENT=production
# Rocca webhook secret for signature confirmation callbacks
ROCCA_WEBHOOK_SECRET=

# ── Redis ────────────────────────────────────────────────────────
# Required for: replay guard, SuggestedParams cache, idempotent execute,
# rate limiting, API key index, telemetry, velocity tracking.
#
# Railway Redis (recommended — TCP, same private network, <2ms/call):
#   Add a Redis plugin to your Railway project. Railway auto-injects:
#   REDIS_PRIVATE_URL  — private network URL (preferred, lowest latency)
#   REDIS_URL          — public URL (fallback / local dev)
#
# Legacy Upstash HTTP REST (higher latency, ~10–30ms/call):
#   Only used if REDIS_PRIVATE_URL and REDIS_URL are both unset.
#   Create a free database at https://console.upstash.com
REDIS_PRIVATE_URL=
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Portal Security ─────────────────────────────────────────────
# Secret used by the developer portal to authenticate /api/portal/* requests.
# Generate: openssl rand -hex 32
# Must match PORTAL_API_SECRET in the portal's .env.local
PORTAL_API_SECRET=

# ── Wallet Guardian (scripts/wallet-guardian.ts) ─────────────────
# 1. Monitors signer ALGO balance — alerts you to top it up manually.
# 2. Sweeps treasury ALGO + USDC to cold wallet when above ceiling.
# No auto-refill. You fund the signer directly with ALGO as needed.
#
# Run:  npm run guardian
#
# ⚠️  REQUIRED:
ALGO_TREASURY_MNEMONIC=<25-word treasury wallet mnemonic>
ALGO_SIGNER_ADDRESS=<signer wallet Algorand address>
#
# Alert threshold — ping you when signer drops below this ALGO amount
SIGNER_LOW_ALERT_ALGO=200
#
# Cold sweep — address is receive-only, private key never touches this process
# Cold wallet MUST be opted in to USDC ASA 31566704 for USDC sweeps to land.
COLD_WALLET_ADDRESS=SII25Z2KDIX2OGL3OOYBBXZ7M4PRPYOU4REXGFOWQ64EXZ5AVNV2JZK3TE
TREASURY_CEILING_ALGO=1000
TREASURY_USDC_CEILING=100
#
# Poll interval
CHECK_INTERVAL_S=10
#
# Telegram — instant phone alerts (recommended)
# Setup: @BotFather → /newbot → token → message bot → getUpdates → chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
#
# Additional webhook (Slack / Discord / generic POST) — optional
ALERT_WEBHOOK_URL=
# Poll interval in ms for wallet-guardian (default 10000 = 10s)
GUARDIAN_INTERVAL_MS=10000

# ── Signing Service (signing microservice RPC) ───────────────────
# Internal URL of the signing-service container.
# Local dev: leave blank — falls back to direct EnvMnemonicAdapter signing.
# Production: set to Railway private network hostname, e.g. http://signing-svc:4021
SIGNING_SERVICE_URL=
# Shared secret for signing service RPC calls — minimum 32 characters.
# Generate: openssl rand -hex 32
# Must match SIGNING_SERVICE_API_KEY on the signing-service container.
SIGNING_SERVICE_API_KEY=

# ── Signer Redis Isolation (Module 7) ────────────────────────────
# Dedicated Redis database for the signing service (recommended).
# If blank, falls back to REDIS_PRIVATE_URL / REDIS_URL (less isolated).
# A separate DB ensures a signing-rate spike doesn't affect main Redis.
#
# Railway: add a second Redis plugin to rocca-signing-service and use:
SIGNER_REDIS_PRIVATE_URL=
SIGNER_REDIS_URL=
# Legacy Upstash fallback:
SIGNER_REDIS_REST_URL=
SIGNER_REDIS_REST_TOKEN=

# ── Security Keys ─────────────────────────────────────────────────
# HMAC-SHA256 key for Tier 1 approval tokens — minimum 32 characters.
# Generate: openssl rand -hex 32
APPROVAL_TOKEN_SECRET=
# Salt for hashing IPs in rejection logs (NEVER rotate casually — breaks log correlation).
# Generate: openssl rand -hex 16
IP_HASH_SALT=
# Emergency halt override key — guards /api/system/halt and /api/system/unhalt.
# Generate: openssl rand -hex 32
HALT_OVERRIDE_KEY=

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins. Default: deny all.
# Example: https://app.example.com,https://portal.example.com
CORS_ALLOWED_ORIGINS=

# ── Rocca Wallet (additional) ────────────────────────────────────
# Algorand public address of the Rocca signing key.
# Required for rekey validation (custody invariant check at boot).
ROCCA_SIGNER_ADDRESS=

# ── Gas Station (src/services/gasStation.ts) ─────────────────────
# Autonomously tops up agent ALGO balances from the treasury wallet.
# The treasury wallet (ALGO_TREASURY_MNEMONIC) must hold ALGO and be opted into USDC.
#
GAS_STATION_ENABLED=true
# Scan interval — 30s balances detection speed vs. Algod call volume.
# Safe burst ceiling per agent: TRIGGER_MICRO / (INTERVAL_S × 1000 µALGO/tx)
# At defaults: 500_000 / (30 × 1000) = ~16 tx/scan-window before trigger fires.
GAS_STATION_INTERVAL_S=30
# Trigger at 0.50 ALGO (500 tx remaining). Gives 500 transactions of runway
# between "top-up needed" detection and actual fund exhaustion — at 7 tx/sec
# that is 71s of buffer, safely above the 30s scan interval.
GAS_STATION_TRIGGER_MICRO=500000
# Top-up 0.70 ALGO (700 tx). Sustained rate per agent: 700 tx / 10-min cooldown
# = 70 tx/min. Covers all realistic AI workloads; swarms doing >7 tx/sec
# sustained will need a shorter cooldown or multiple agent accounts.
GAS_STATION_TOPUP_MICRO=700000

# ── ALGO Price Oracle (src/services/algoPrice.ts) ────────────────
# Used to compute dynamic USDC registration fees for USDC-native onboarding.
# On oracle failure, the last known good price is used (never a hardcoded floor).
# If no price has ever been fetched, onboarding quotes are refused until CoinGecko responds.
#
ALGO_PRICE_CEILING_USDC=10.0

# ── Treasury Low-Balance Alert (scripts/wallet-guardian.ts) ──────
# Alert when gas station treasury ALGO drops below this amount.
# At GAS_STATION_TOPUP_MICRO=700000 (0.70 ALGO/agent), 10 ALGO covers ~14 top-ups.
TREASURY_LOW_ALERT_ALGO=10

# ── On-Chain Monitor (Module 9) ──────────────────────────────────
# Set false to disable on-chain outflow reconciliation (not recommended in production).
ONCHAIN_MONITOR_ENABLED=true
# µALGO tolerance band for transaction fees. Default: 10_000_000 = 10 ALGO.
ONCHAIN_ALGO_TOLERANCE_MICRO=10000000
# µUSDC tolerance. Default 0 = any unexplained USDC outflow immediately halts the wallet.
ONCHAIN_USDC_TOLERANCE_MICRO=0
