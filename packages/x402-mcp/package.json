{
  "name": "@algo-wallet/x402-mcp",
  "version": "0.1.0",
  "description": "MCP server for x402 Algorand payments — one tool: pay_with_x402",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "x402-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "algosdk": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "algorand",
    "x402",
    "usdc",
    "payments",
    "ai-agent",
    "claude"
  ]
}
