FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=production

COPY package.json package-lock.json ./
COPY packages/ ./packages/
# Include devDependencies — tsx and pino-pretty are needed at runtime
RUN npm ci --ignore-scripts && npm cache clean --force

COPY tsconfig.json ./
COPY src/ ./src/
COPY scripts/wallet-guardian.ts ./scripts/

CMD ["./node_modules/.bin/tsx", "scripts/wallet-guardian.ts"]
